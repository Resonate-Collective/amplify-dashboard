# Copy to .env.local for local dev, or set these as Railway variables.
# NEVER commit real values.

# Google Sheet (source of truth). Defaults to the Amplify log if unset.
SHEET_ID=1ydbAZ-qGqwavxJ2xVbFmRr_s89RyeY-6nCSq8_x8iNE

# Service account JSON, as a SINGLE-LINE string (the whole {...} object) or base64.
# Reuse: okr-manager-agent@director-sandbox.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# OAuth 2.0 Web client (for resonate.net Google sign-in)
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxx

# Session/JWT signing secret. Generate: `openssl rand -base64 32`
SESSION_SECRET=change-me

# Workspace domain allowed to sign in
ALLOWED_DOMAIN=resonate.net

# Public base URL of the deployed app (used by Auth.js for callback URLs).
# Locally: http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
